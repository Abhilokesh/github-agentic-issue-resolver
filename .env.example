# Copy this file to .env and fill in real values. Never commit .env itself.

# Google AI Studio / Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Fine-grained GitHub Personal Access Token, scoped ONLY to the sandbox repo,
# with Issues: read/write and Pull requests: read/write. No admin, no other repos.
GITHUB_PERSONAL_ACCESS_TOKEN=

# owner/name of the seeded sandbox repo the agent operates against
SANDBOX_REPO=your-github-username/agent-sandbox-repo

# Optional: set to export OpenTelemetry spans to Google Cloud Observability
# instead of the local console/file exporter. Requires an active GCP project
# with billing enabled.
# OTEL_EXPORT_TARGET=gcp
GOOGLE_CLOUD_PROJECT=
